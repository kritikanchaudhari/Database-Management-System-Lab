mysql> -- 2. CURSOR WITH CONTROL STRUCTURE + HANDLER
mysql> -- Purpose: Calculate bonus based on rating and insert into report table
mysql> -- ==============================
mysql>
mysql> DELIMITER //
mysql>
mysql> CREATE PROCEDURE GenerateBonusReport()
    -> BEGIN
    ->     -- Variable declarations
    ->     DECLARE v_emp_id INT;
    ->     DECLARE v_emp_name VARCHAR(50);
    ->     DECLARE v_salary DECIMAL(10,2);
    ->     DECLARE v_rating INT;
    ->     DECLARE v_bonus DECIMAL(10,2);
    ->
    ->     -- Cursor declaration
    ->     DECLARE done INT DEFAULT 0;
    ->
    ->     DECLARE emp_cursor CURSOR FOR
    ->         SELECT e.emp_id, e.emp_name, e.salary, a.rating
    ->         FROM Employee e
    ->         JOIN Appraisal a ON e.emp_id = a.emp_id;
    ->
    ->     -- Exception handler (when no more rows)
    ->     DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;
    ->
    ->     -- Clear previous data
    ->     DELETE FROM Employee_Bonus_Report;
    ->
    ->     OPEN emp_cursor;
    ->
    ->     read_loop: LOOP
    ->         FETCH emp_cursor INTO v_emp_id, v_emp_name, v_salary, v_rating;
    ->
    ->         IF done = 1 THEN
    ->             LEAVE read_loop;
    ->         END IF;
    ->
    ->         -- CONTROL STRUCTURE (IF-ELSE for bonus calculation)
    ->         IF v_rating = 5 THEN
    ->             SET v_bonus = v_salary * 0.20;
    ->         ELSEIF v_rating = 4 THEN
    ->             SET v_bonus = v_salary * 0.15;
    ->         ELSEIF v_rating = 3 THEN
    ->             SET v_bonus = v_salary * 0.10;
    ->         ELSE
    ->             SET v_bonus = v_salary * 0.05;
    ->         END IF;
    ->
    ->         -- Insert into result table
    ->         INSERT INTO Employee_Bonus_Report
    ->         VALUES (v_emp_id, v_emp_name, v_salary, v_rating, v_bonus);
    ->
    ->     END LOOP;
    ->
    ->     CLOSE emp_cursor;
    ->
    -> END //
